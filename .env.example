# HOPE Hub - local example environment

# NextAuth
NEXTAUTH_URL=http://localhost:8013
NEXTAUTH_SECRET=replace-with-32-plus-char-random-secret

# Authentik OIDC
AUTHENTIK_ISSUER=https://auth.example.com/application/o/hope-hub/
AUTHENTIK_CLIENT_ID=replace-with-client-id
AUTHENTIK_CLIENT_SECRET=replace-with-client-secret
AUTHENTIK_SCOPE="openid profile email groups"

# Prisma / PostgreSQL
DATABASE_URL=postgresql://hope_hub:change_me@127.0.0.1:5432/hope_hub
