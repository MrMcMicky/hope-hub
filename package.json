{
  "name": "hope-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "next dev -H 0.0.0.0 -p 8013",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -H 0.0.0.0 -p 8014",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test:e2e": "bash -lc 'set -a; source .env.local; set +a; playwright test'",
    "test:e2e:headed": "bash -lc 'set -a; source .env.local; set +a; playwright test --headed'",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "next": "16.1.6",
    "next-auth": "^4.24.11",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
