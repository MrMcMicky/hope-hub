generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SHIFT_LEAD
  SHIFT_WORKER
  AUDITOR
  BILLING
}

enum DataClass {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  HIGHLY_SENSITIVE
}

enum LegalBasis {
  CONSENT
  CONTRACT
  LEGAL_OBLIGATION
  VITAL_INTEREST
  PUBLIC_TASK
  LEGITIMATE_INTEREST
}

enum SharePolicy {
  INTERNAL_ONLY
  NEED_TO_KNOW
  AUTHORITY_ONLY
  PARTNER_ALLOWED
}

enum StayStatus {
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum CaseStatus {
  INTAKE
  ACTIVE
  FOLLOW_UP
  WAITLIST
  CLOSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ProgramArea {
  BEGEGNUNG
  BETREUEN
  BEHERBERGEN
  BESCHAEFTIGEN
}

enum TaskPriority {
  P1
  P2
  P3
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum InvoiceStatus {
  DRAFT
  READY
  SUBMITTED
  PAID
  CANCELLED
}

enum InvoiceLineSource {
  STAY
  SERVICE_EVENT
  COST_APPROVAL
  MANUAL
}

enum CostApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ExportPackageStatus {
  DRAFT
  READY
  RELEASED
  CANCELLED
}

enum RetentionStatus {
  ACTIVE
  DUE
  ARCHIVED
  DELETION_SCHEDULED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  EXPORT
  PERMISSION_CHANGE
  SYNC_APPEND
  LOGIN
  LOGOUT
}

model User {
  id          String   @id @default(cuid())
  externalId  String   @unique
  email       String   @unique
  displayName String?
  role        UserRole @default(SHIFT_WORKER)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments          CaseAssignment[]
  auditEvents          AuditEvent[]     @relation("AuditActor")
  staysCreated         Stay[]           @relation("StayCreator")
  serviceEventsCreated ServiceEvent[]   @relation("ServiceEventCreator")
  tasksCreated         Task[]           @relation("TaskCreator")
  syncClients          SyncClient[]
  invoicesCreated      InvoiceDraft[]   @relation("InvoiceCreator")
  exportsCreated       ExportPackage[]  @relation("ExportPackageCreator")
  costApprovalsCreated CostApproval[]   @relation("CostApprovalCreator")
}

model Case {
  id                  String          @id @default(cuid())
  caseRef             String          @unique
  subjectDisplayName  String
  status              CaseStatus      @default(INTAKE)
  riskLevel           RiskLevel       @default(MEDIUM)
  programArea         ProgramArea
  offering            String
  assignedTeam        String?
  nextActionAt        DateTime?
  intakeAt            DateTime        @default(now())
  dataClass           DataClass
  purpose             String
  legalBasis          LegalBasis
  sharePolicy         SharePolicy
  retentionRule       String
  legalHold           Boolean         @default(false)
  retentionDueAt      DateTime?
  retentionStatus     RetentionStatus @default(ACTIVE)
  retentionLastCheck  DateTime?
  archivedAt          DateTime?
  scheduledDeletionAt DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  stays          Stay[]
  serviceEvents  ServiceEvent[]
  tasks          Task[]
  costApprovals  CostApproval[]
  invoices       InvoiceDraft[]
  invoiceLines   InvoiceLine[]
  exportPackages ExportPackage[]
  documents      DocumentMeta[]
  auditEvents    AuditEvent[]
  assignments    CaseAssignment[]
  syncEvents     SyncEvent[]

  @@index([status])
  @@index([programArea])
  @@index([dataClass])
  @@index([legalHold])
  @@index([retentionStatus])
  @@index([retentionDueAt])
  @@index([scheduledDeletionAt])
}

model CaseAssignment {
  id         String    @id @default(cuid())
  caseId     String
  userId     String
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
  @@index([userId])
}

model Stay {
  id          String      @id @default(cuid())
  caseId      String
  checkInAt   DateTime
  checkOutAt  DateTime?
  status      StayStatus  @default(CHECKED_IN)
  dataClass   DataClass
  purpose     String
  legalBasis  LegalBasis
  sharePolicy SharePolicy
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  case          Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("StayCreator", fields: [createdById], references: [id], onDelete: SetNull)
  serviceEvents ServiceEvent[]

  @@index([caseId, checkInAt])
}

model ServiceEvent {
  id          String      @id @default(cuid())
  caseId      String
  stayId      String?
  eventType   String
  occurredAt  DateTime
  notes       String?
  dataClass   DataClass
  purpose     String
  legalBasis  LegalBasis
  sharePolicy SharePolicy
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  case      Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stay      Stay? @relation(fields: [stayId], references: [id], onDelete: SetNull)
  createdBy User? @relation("ServiceEventCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([caseId, occurredAt])
}

model Task {
  id          String       @id @default(cuid())
  caseId      String
  title       String
  details     String?
  ownerName   String?
  dueAt       DateTime?
  priority    TaskPriority @default(P2)
  status      TaskStatus   @default(OPEN)
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  case      Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy User? @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([caseId, status, dueAt])
}

model InvoiceDraft {
  id            String        @id @default(cuid())
  caseId        String
  invoiceRef    String        @unique
  periodStart   DateTime
  periodEnd     DateTime
  status        InvoiceStatus @default(DRAFT)
  currency      String        @default("CHF")
  subtotalCents Int           @default(0)
  taxCents      Int           @default(0)
  totalCents    Int           @default(0)
  notes         String?
  costApprovalId String?
  createdById   String?
  issuedAt      DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  case         Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  costApproval CostApproval? @relation(fields: [costApprovalId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lines        InvoiceLine[]

  @@index([caseId, status, updatedAt])
  @@index([costApprovalId])
}

model CostApproval {
  id                  String             @id @default(cuid())
  caseId              String
  approvalRef         String             @unique
  authorityName       String
  approvedAmountCents Int
  currency            String             @default("CHF")
  validFrom           DateTime
  validUntil          DateTime
  status              CostApprovalStatus @default(DRAFT)
  notes               String?
  createdById         String?
  submittedAt         DateTime?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  case      Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("CostApprovalCreator", fields: [createdById], references: [id], onDelete: SetNull)
  invoices  InvoiceDraft[]

  @@index([caseId, status, validUntil])
}

model InvoiceLine {
  id             String            @id @default(cuid())
  invoiceDraftId String
  caseId         String
  sourceType     InvoiceLineSource
  sourceId       String?
  description    String
  quantity       Int               @default(1)
  unitPriceCents Int
  lineTotalCents Int
  occurredAt     DateTime?
  createdAt      DateTime          @default(now())

  invoiceDraft InvoiceDraft @relation(fields: [invoiceDraftId], references: [id], onDelete: Cascade)
  case         Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([invoiceDraftId, createdAt])
  @@index([caseId, sourceType])
}

model ExportRecipient {
  id                String   @id @default(cuid())
  recipientRef      String   @unique
  label             String
  organisation      String?
  channel           String   @default("sftp")
  endpoint          String?
  authorityApproved Boolean  @default(false)
  keyFingerprint    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  packages ExportPackage[]

  @@index([authorityApproved])
}

model ExportPackage {
  id          String              @id @default(cuid())
  caseId      String
  exportRef   String              @unique
  recipientId String
  status      ExportPackageStatus @default(DRAFT)
  payloadType String              @default("case_bundle")
  encrypted   Boolean             @default(true)
  purpose     String
  legalBasis  LegalBasis
  sharePolicy SharePolicy
  payloadHash String?
  expiresAt   DateTime?
  releasedAt  DateTime?
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  case      Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  recipient ExportRecipient @relation(fields: [recipientId], references: [id], onDelete: Restrict)
  createdBy User?           @relation("ExportPackageCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([caseId, status, updatedAt])
  @@index([recipientId, status])
}

model DocumentMeta {
  id             String      @id @default(cuid())
  caseId         String
  objectKey      String      @unique
  filename       String
  mimeType       String
  bytes          Int
  checksumSha256 String
  encrypted      Boolean     @default(true)
  dataClass      DataClass
  purpose        String
  legalBasis     LegalBasis
  sharePolicy    SharePolicy
  createdAt      DateTime    @default(now())
  deletedAt      DateTime?

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
}

model AuditEvent {
  id         String      @id @default(cuid())
  caseId     String?
  action     AuditAction
  entityType String
  entityId   String
  actorId    String?
  eventTs    DateTime    @default(now())
  payload    Json
  prevHash   String?
  eventHash  String

  case  Case? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([caseId, eventTs])
  @@index([action, eventTs])
}

model SyncClient {
  id          String    @id @default(cuid())
  clientRef   String    @unique
  userId      String
  deviceLabel String?
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  events SyncEvent[]

  @@index([userId])
}

model SyncEvent {
  id           String    @id @default(cuid())
  syncClientId String
  caseId       String
  sequence     Int
  eventType    String
  payload      Json
  receivedAt   DateTime  @default(now())
  appliedAt    DateTime?

  syncClient SyncClient @relation(fields: [syncClientId], references: [id], onDelete: Cascade)
  case       Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([syncClientId, sequence])
  @@index([caseId, receivedAt])
}
